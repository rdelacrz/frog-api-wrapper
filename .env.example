# Required: Your Frog API key (get one at https://frogapi.app)
FROG_API_KEY=frog_sk_your_api_key_here

# Optional: Frog API base URL (default: https://frogapi.app/v1)
FROG_BASE_URL=https://frogapi.app/v1

# Optional: Host/port for the local wrapper server (defaults: 127.0.0.1 / 3000)
HOST=127.0.0.1
PORT=3000

# Optional: Log level filter (default: info)
RUST_LOG=frog_api_wrapper=info
